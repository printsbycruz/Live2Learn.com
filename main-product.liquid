<section class="story" {% if section.settings.image != blank %}style="background-image:url('{{ section.settings.image | image_url: width: 2400 }}')"{% endif %}>
  <div class="story-content">
    <div class="section-kicker">{{ section.settings.kicker }}</div>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
    {% if section.settings.button_label != blank %}
      <a class="button button--light" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name":"Story banner",
  "settings":[
    {"type":"image_picker","id":"image","label":"Background image"},
    {"type":"text","id":"kicker","label":"Small text","default":"MORE THAN A BRAND"},
    {"type":"text","id":"heading","label":"Heading","default":"LIVE. LEARN. KEEP GOING."},
    {"type":"textarea","id":"text","label":"Text","default":"Live2Learn represents growth through every experience—the wins, the losses, and everything in between."},
    {"type":"text","id":"button_label","label":"Button label","default":"OUR STORY"},
    {"type":"url","id":"button_link","label":"Button link"}
  ],
  "presets":[{"name":"Story banner"}]
}
{% endschema %}
