<section class="hero" {% if section.settings.image != blank %}style="background-image:url('{{ section.settings.image | image_url: width: 2400 }}')"{% endif %}>
  <div class="page-width hero-content">
    <div class="hero-kicker">{{ section.settings.kicker }}</div>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>
    {% if section.settings.button_label != blank %}
      <a class="button button--light" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name":"Hero",
  "settings":[
    {"type":"image_picker","id":"image","label":"Background image"},
    {"type":"text","id":"kicker","label":"Small text","default":"THE FIRST DROP"},
    {"type":"text","id":"heading","label":"Heading","default":"LIVE2LEARN"},
    {"type":"textarea","id":"text","label":"Text","default":"Every lesson shapes who you become."},
    {"type":"text","id":"button_label","label":"Button label","default":"SHOP THE FIRST DROP"},
    {"type":"url","id":"button_link","label":"Button link"}
  ],
  "presets":[{"name":"Hero"}]
}
{% endschema %}
