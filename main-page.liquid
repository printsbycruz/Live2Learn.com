<section class="section">
  <div class="page-width newsletter">
    <div class="section-kicker">{{ section.settings.kicker }}</div>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.text }}</p>
    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="Email address" required>
      <button class="button" type="submit">Join</button>
    {% endform %}
  </div>
</section>
{% schema %}
{
  "name":"Email signup",
  "settings":[
    {"type":"text","id":"kicker","label":"Small text","default":"BE FIRST"},
    {"type":"text","id":"heading","label":"Heading","default":"BE PART OF WHAT'S NEXT"},
    {"type":"textarea","id":"text","label":"Text","default":"Get early access to future drops, restocks, and exclusive releases."}
  ],
  "presets":[{"name":"Email signup"}]
}
{% endschema %}
